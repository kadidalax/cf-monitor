{
  "name": "cf-monitor",
  "version": "1.0.0",
  "description": "Cloudflare Worker 探针监控系统 - 基于 komari 重构",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit",
    "build:frontend": "npm --prefix ../frontend run build",
    "smoke:e2e": "node ./scripts/smoke-e2e.mjs",
    "local-deploy:coverage": "node ./scripts/local-deploy-coverage.mjs",
    "predeploy": "npm run build:frontend && npm run build",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create cf-monitor-db",
    "db:migrate:local": "node ./scripts/run-migrations.mjs local",
    "db:migrate:remote": "node ./scripts/run-migrations.mjs remote",
    "db:migrate:client-sort:local": "node ./scripts/run-migrations.mjs local",
    "db:migrate:client-sort:remote": "node ./scripts/run-migrations.mjs remote",
    "db:indexes:local": "wrangler d1 execute cf-monitor-db --local --file=./migrations/003_query_indexes.sql",
    "db:indexes:remote": "wrangler d1 execute cf-monitor-db --remote --file=./migrations/003_query_indexes.sql",
    "db:seed:local": "wrangler d1 execute cf-monitor-db --local --file=./migrations/002_seed_demo.sql",
    "db:reset:local": "wrangler d1 execute cf-monitor-db --local --file=./migrations/000_reset_local.sql && npm run db:migrate:local && npm run db:seed:local"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "jose": "^5.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "esbuild": "^0.27.3",
    "miniflare": "^4.20260603.0",
    "typescript": "^5.0.0",
    "wrangler": "^4.98.0"
  }
}
